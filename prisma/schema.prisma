datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

// 1. USER MODEL (For the "Esdenita" community members)
model User {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique @db.VarChar(50)
  email     String   @unique @db.VarChar(100)
  avatarUrl    String?  @map("avatar_url")
  role         Role     @default(USER)
  password     String?  @db.VarChar(255)
  refreshToken String?  @map("refresh_token") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  
  // Relations
  stories   CommunityStory[]
  votes     StoryVote[]

  @@map("users")
}

// 2. GUEST MODEL (e.g., Comedians, musicians, special guests)
model Guest {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(100)
  bio             String?
  twitterHandle   String?   @map("twitter_handle") @db.VarChar(50)
  instagramHandle String?   @map("instagram_handle") @db.VarChar(50)
  
  // Implicit Many-to-Many relation with Episodes
  episodes        Episode[] @relation("EpisodeGuests")

  @@map("guests")
}

// 3. EPISODE MODEL (Centralizes YouTube, Spotify, and Patreon)
model Episode {
  id              String         @id @default(uuid()) @db.Uuid
  episodeNumber   Int?           @unique @map("episode_number") // NULL for special mini-clips or bonus content
  title           String         @db.VarChar(255)
  description     String?
  platformType    PlatformType   @map("platform_type")
  contentUrl      String         @map("content_url")
  thumbnailUrl    String?        @map("thumbnail_url")
  publishedAt     DateTime       @map("published_at") @db.Date
  isExclusive     Boolean        @default(false) @map("is_exclusive")
  durationSeconds Int?           @map("duration_seconds")
  
  // Relations
  guests          Guest[]        @relation("EpisodeGuests")
  insideJokes     InsideJoke[]

  @@map("episodes")
}

enum PlatformType {
  YOUTUBE
  SPOTIFY
  PATREON
}

// 4. INSIDE JOKE / "LORE" MODEL (For the smart timestamp search engine)
model InsideJoke {
  id                String   @id @default(uuid()) @db.Uuid
  episodeId         String   @map("episode_id") @db.Uuid
  startTimeStamp    String   @map("start_timestamp") // Stored as String (e.g., "00:14:23") for easy timestamp parsing
  endTimeStamp      String?  @map("end_timestamp")
  keyConcept        String   @map("key_concept") @db.VarChar(100) // e.g., 'Chupis', 'Leo's deodorant'
  transcriptContext String   @map("transcript_context")
  
  // Relations
  episode           Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@map("inside_jokes")
}

// 5. TOUR SHOWS MODEL (For the interactive world tour map)
model TourShow {
  id          String      @id @default(uuid()) @db.Uuid
  city        String      @db.VarChar(100)
  country     String      @db.VarChar(100)
  venueName   String      @map("venue_name") @db.VarChar(150)
  showDate    DateTime    @map("show_date") @db.Timestamptz
  ticketUrl   String?     @map("ticket_url")
  ticketStatus TicketStatus @default(AVAILABLE) @map("ticket_status")
  latitude    Decimal?    @db.Decimal(9, 6)
  longitude   Decimal?    @db.Decimal(9, 6)

  @@map("tour_shows")
}

enum TicketStatus {
  AVAILABLE
  FEW_TICKETS // Equivalent to 'pocos cufos'
  SOLD_OUT
}

// 6. COMMUNITY STORIES MODEL (For the "Wall of Shame" anonymous/public section)
model CommunityStory {
  id                 String      @id @default(uuid()) @db.Uuid
  userId             String?     @map("user_id") @db.Uuid // NULL allows for 100% anonymous submissions
  title              String      @db.VarChar(150)
  content            String
  category           String?     @db.VarChar(50) // e.g., 'Bad dates', 'Awkward moments'
  submittedAt        DateTime    @default(now()) @map("submitted_at") @db.Timestamptz
  isApproved         Boolean     @default(false) @map("is_approved") // Moderation queue flag
  
  // Relations
  user               User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  votes              StoryVote[]

  @@map("community_stories")
}

// 7. STORY VOTE MODEL (Reddit-style upvote/downvote system)
model StoryVote {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  storyId   String         @map("story_id") @db.Uuid
  voteValue Int            @map("vote_value") // 1 for Upvote, -1 for Downvote

  // Relations
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     CommunityStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  // Enforces that a user can only vote once per story
  @@unique([userId, storyId])
  @@map("story_votes")
}

// 8. MEDIA MODEL (Shared images for TourShows and Episodes)
model Media {
  id         String          @id @default(uuid()) @db.Uuid
  entityType MediaEntityType @map("entity_type")
  entityId   String          @map("entity_id") @db.Uuid
  url        String
  key        String
  isPrimary  Boolean         @default(false) @map("is_primary")
  sortOrder  Int             @default(0) @map("sort_order")
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("media")
}

enum MediaEntityType {
  TOUR_SHOW
  EPISODE
}